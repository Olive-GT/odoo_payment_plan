<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <!-- Root menu for Payment Plans (top-level) -->
    <menuitem id="menu_payment_plans_root" name="Payment Plans" sequence="5"/>

    <!-- Action to open payment plans -->
    <record id="action_payment_plans" model="ir.actions.act_window">
        <field name="name">Payment Plans</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">payment.plan</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_posted': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first payment plan
            </p>
            <p>
                Payment plans allow you to schedule payments for your customers.
            </p>
        </field>
    </record>

    <record id="action_payment_plans_current_company" model="ir.actions.server">
        <field name="name">Payment Plans Current Company</field>
        <field name="model_id" ref="model_payment_plan"/>
        <field name="state">code</field>
        <field name="code">
action = env.ref('olivegt_sale_payment_plans.action_payment_plans').read()[0]
action['domain'] = [('company_id', '=', env.company.id)]
action['context'] = dict(env.context, search_default_posted=1, default_company_id=env.company.id)
        </field>
    </record>

    <!-- Sub Menus -->
    <menuitem 
        id="menu_payment_plans" 
        name="Payment Plans" 
        parent="menu_payment_plans_root" 
        action="action_payment_plans_current_company" 
        sequence="10"/>
</data>
</odoo>
