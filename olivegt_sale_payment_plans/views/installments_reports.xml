<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <record id="action_report" model="ir.actions.act_window">
            <field name="name">Lista de Reportes</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">olivegt_sale_payment_plans.reporte_installments</field> 
            <field name="view_mode">list,form</field> <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay reportes definidos aún. ¡Pero el menú funciona!
                </p>
            </field>
        </record>

        <record id="view_mi_modulo_reporte_list" model="ir.ui.view">
            <field name="name">olivegt_sale_payment_plans.reporte.list</field>
            <field name="model">olivegt_sale_payment_plans.reporte_installments</field>
            <field name="arch" type="xml">
                <list string="Reportes Disponibles" create="false" edit="false">
                    <field name="name" string="Nombre del Reporte"/>
                    <field name="description" string="Descripción"/>
                    
                    <button name="action_descargar_reporte" 
                            string="Descargar" 
                            type="object" 
                            icon="fa-download" 
                            class="btn-primary"/>
                </list>
            </field>
        </record>

        <menuitem id="reports_submenu" 
                  name="Reports" 
                  parent="menu_payment_plans_root" 
                  action="action_report" 
                  sequence="30"/>
    </data>
</odoo>