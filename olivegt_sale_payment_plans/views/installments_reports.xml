<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <record id="action_report" model="ir.actions.act_window">
            <field name="name">Reportes</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">olivegt_sale_payment_plans.reporte_installments</field> 
            <field name="view_mode">list,form</field> <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay reportes definidos aún.
                </p>
            </field>
        </record>

        <record id="view_reporte_installments_list" model="ir.ui.view">
            <field name="name">olivegt_sale_payment_plans.reporte_installments.list</field>
            <field name="model">olivegt_sale_payment_plans.reporte_installments</field>
            <field name="arch" type="xml">
                <list string="Formatos Disponibles" create="false" delete="false" edit="false">
                    <field name="name" string="Name"/>
                    <field name="description" string="Description"/>
                    
                    <button name="action_descargar_reporte" 
                            string="Descargar reporte (.xlsx)" 
                            type="object" 
                            icon="fa-file-excel-o" 
                            class="btn-success"/>
                </list>
            </field>
        </record>

        <menuitem id="reports_submenu" 
                  name="Reports" 
                  parent="menu_payment_plans_root" 
                  action="action_report" 
                  sequence="30"/>
    </data>
</odoo>